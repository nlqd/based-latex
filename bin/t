#!/usr/bin/env python3
"""
t — Cargo-style package manager wrapper for TeX Live / TinyTeX.

Usage:
  t search <terms...>    Search tlmgr by package name and filename.
                         Terms ending in .sty/.cls/.tex are file searches.
                         Example: t search siunitx tikz-cd amsmath.sty

  t add <pkgs...>        Install via tlmgr and record in tex-packages.toml.
                         Example: t add tikz-cd pgfplots

  t diagnose [LOG]       Parse a build log for missing files, fonts, styles,
                         and tikz libraries. Prints a suggested install command.
                         Classifies errors by kind (package, class, graphic,
                         input, font, style, tikz-library) and gives guidance
                         for each. Wired as $failure_cmd in .latexmkrc so it
                         runs automatically on build failure.
                         Default log: build/aux/main.log

  t missing [LOG]        Like diagnose, but prompts to install afterward.

  t restore              Install everything declared in tex-packages.toml.
"""
from __future__ import annotations
import argparse
import re
import subprocess
import sys
from pathlib import Path

try:
    import tomllib  # py 3.11+
except ModuleNotFoundError:
    import tomli as tomllib  # type: ignore

MANIFEST = Path("tex-packages.toml")
# Matches $aux_dir in .latexmkrc; latexmk writes the log next to the .aux files.
DEFAULT_LOG = Path("build/aux/main.log")

# --- terminal colors -------------------------------------------------------
class C:
    R = "\033[31m"; G = "\033[32m"; Y = "\033[33m"
    B = "\033[34m"; DIM = "\033[2m"; BOLD = "\033[1m"; END = "\033[0m"
    @classmethod
    def disable(cls):
        for k in list(cls.__dict__):
            if k.isupper(): setattr(cls, k, "")

if not sys.stdout.isatty():
    C.disable()

def info(msg):  print(f"{C.B}info{C.END}  {msg}")
def warn(msg):  print(f"{C.Y}warn{C.END}  {msg}")
def err(msg):   print(f"{C.R}error{C.END} {msg}", file=sys.stderr)
def ok(msg):    print(f"{C.G}ok{C.END}    {msg}")

# --- tlmgr helpers ---------------------------------------------------------
FILE_EXTS = (".sty", ".cls", ".tex", ".ldf", ".fd", ".def", ".cfg", ".tfm",
             ".otf", ".ttf", ".map", ".enc")

def run(cmd):
    return subprocess.run(cmd, capture_output=True, text=True)

def looks_like_file(term: str) -> bool:
    return term.lower().endswith(FILE_EXTS)

def search_one(term: str) -> set[str]:
    """Search tlmgr by *both* package name and file name. Return matching pkg names."""
    found: set[str] = set()

    # tlmgr file search: match the basename anywhere in path; '/' prefix anchors
    # to the filename component, which is what we usually want.
    if looks_like_file(term):
        anchor = f"/{term}"
    else:
        anchor = term  # let tlmgr regex it; we also do name search below

    r_file = run(["tlmgr", "search", "--global", "--file", anchor])
    cur_pkg: str | None = None
    for line in r_file.stdout.splitlines():
        m = re.match(r"^([A-Za-z0-9][\w\-\+\.]*):\s*$", line)
        if m:
            cur_pkg = m.group(1)
            found.add(cur_pkg)

    # Skip name search for things that are clearly filenames.
    if not looks_like_file(term):
        r_name = run(["tlmgr", "search", "--global", term])
        for line in r_name.stdout.splitlines():
            m = re.match(r"^(\S+) - ", line)
            if m:
                found.add(m.group(1))

    return found

def search(terms: list[str]) -> dict[str, set[str]]:
    """Return {term: {pkg, pkg, ...}} for each query term."""
    return {t: search_one(t) for t in terms}

# --- log parsing -----------------------------------------------------------
# Each issue is a (kind, name) tuple. Kinds:
#   package       — a .sty (installable via tlmgr)
#   class         — a .cls (installable via tlmgr)
#   graphic       — a missing asset referenced by \includegraphics
#   input         — a missing .tex referenced by \input / \include
#   font          — an OTF font fontspec couldn't load
#   style         — a biblatex style that doesn't exist
#   tikz-library  — a tikz library name that doesn't resolve

# "File `X' not found" — generic; classified by context below. The `!`
# prefix disappears in -file-line-error mode (becomes `path:N:`), so we
# don't anchor on it.
FILE_NOT_FOUND = [
    re.compile(r"LaTeX Error: File `([^']+)' not found"),
    re.compile(r"I can't find file `([^']+)'"),
    re.compile(r"Package .* Error: File `([^']+)' not found"),
    re.compile(r"pdfTeX error: .* could not find file `([^']+)'"),
    re.compile(r"Package .* Error: Unable to load picture file `([^']+)'"),
]
FONTSPEC_FONT   = re.compile(r'\(fontspec\)\s+The font "([^"]+)" cannot be')
BIBLATEX_STYLE  = re.compile(r"Package biblatex Error: Style '([^']+)' not found")
TIKZ_LIBRARY    = re.compile(
    r"Package (?:tikz|pgf) Error: I did not find the (?:tikz |pgf )?library '([^']+)'"
)
# `l.<n>` source-context line lets us tell graphics from inputs from packages.
SRCLINE_RE      = re.compile(r"^l\.\d+\s+(.*)$")

def classify_file(fname: str, context: str) -> str:
    """Classify a 'File `X' not found' error by surrounding source context."""
    if re.search(r"\\includegraphics|\\includepdf|\\pgfimage", context):
        return "graphic"
    if re.search(r"\\input\b|\\include\b|\\subfile\b", context):
        return "input"
    if fname.endswith(".cls"):
        return "class"
    return "package"

def parse_log(path: Path) -> list[tuple[str, str]]:
    """Return deduped (kind, name) tuples for every issue mentioned in the log."""
    if not path.exists():
        err(f"log not found: {path}")
        sys.exit(2)

    lines = path.read_text(errors="replace").splitlines()
    issues: list[tuple[str, str]] = []
    seen: set[tuple[str, str]] = set()

    def add(kind: str, name: str):
        key = (kind, name)
        if key not in seen:
            seen.add(key)
            issues.append(key)

    for i, line in enumerate(lines):
        if m := FONTSPEC_FONT.search(line):
            add("font", m.group(1))
            continue
        if m := BIBLATEX_STYLE.search(line):
            add("style", m.group(1))
            continue
        if m := TIKZ_LIBRARY.search(line):
            add("tikz-library", m.group(1))
            continue

        for pat in FILE_NOT_FOUND:
            m = pat.search(line)
            if not m:
                continue
            fname = m.group(1).strip()
            # Look ahead a few lines for the `l.<n>` source context.
            context = ""
            for ln in lines[i + 1 : i + 10]:
                cm = SRCLINE_RE.match(ln)
                if cm:
                    context = cm.group(1)
                    break
            kind = classify_file(fname, context)
            # Bare names without an extension default to .sty (latex's own
            # error often drops the suffix).
            if kind == "package" and "." not in fname and not fname.startswith("/"):
                fname += ".sty"
            add(kind, fname)
            break

    return issues

# --- manifest --------------------------------------------------------------
def load_manifest() -> dict:
    if not MANIFEST.exists():
        return {"packages": {}}
    with MANIFEST.open("rb") as f:
        return tomllib.load(f)

def write_manifest_entries(pkgs: list[str]):
    """Append packages to the manifest if not already present. Plain-text edit
    so we preserve user comments and ordering."""
    if not MANIFEST.exists():
        MANIFEST.write_text("[packages]\n")
    current = MANIFEST.read_text()
    existing = set(re.findall(r"^([A-Za-z0-9][\w\-\+\.]*)\s*=", current, re.M))
    new = [p for p in pkgs if p not in existing]
    if not new:
        return
    if not current.endswith("\n"):
        current += "\n"
    current += "\n".join(f'{p} = "*"' for p in new) + "\n"
    MANIFEST.write_text(current)

# --- subcommands -----------------------------------------------------------
def cmd_search(args):
    results = search(args.terms)
    any_hit = False
    for term, pkgs in results.items():
        if pkgs:
            any_hit = True
            print(f"{C.BOLD}{term}{C.END} → {', '.join(sorted(pkgs))}")
        else:
            print(f"{C.BOLD}{term}{C.END} {C.DIM}(no match){C.END}")
    return 0 if any_hit else 1

def cmd_add(args):
    r = subprocess.run(["tlmgr", "install", *args.pkgs])
    if r.returncode != 0:
        err("tlmgr install failed")
        return r.returncode
    write_manifest_entries(args.pkgs)
    ok(f"installed and recorded: {', '.join(args.pkgs)}")
    return 0

def cmd_diagnose(args, *, do_install: bool = False):
    log = Path(args.log) if args.log else DEFAULT_LOG
    issues = parse_log(log)
    if not issues:
        ok("no issues detected in log")
        return 0

    by_kind: dict[str, list[str]] = {}
    for kind, name in issues:
        by_kind.setdefault(kind, []).append(name)

    # Files we can plausibly resolve via tlmgr.
    installable: list[str] = []

    if files := by_kind.get("package"):
        warn(f"missing package file(s):")
        for f in files:
            print(f"  - {f}")
        installable.extend(files)

    if files := by_kind.get("class"):
        warn(f"missing document class(es):")
        for f in files:
            print(f"  - {f}")
        installable.extend(files)

    if names := by_kind.get("graphic"):
        warn("missing graphic asset(s) — not a tlmgr package; check figures/ or fix the path:")
        for n in names:
            print(f"  - \\includegraphics{{{n}}}")

    if names := by_kind.get("input"):
        warn("missing input/include file(s) — create it or fix the path:")
        for n in names:
            print(f"  - \\input{{{n}}}")

    if names := by_kind.get("font"):
        warn("font not loadable — install via your OS font dir or `t add <font-pkg>`:")
        for n in names:
            print(f"  - {n}")
        info("e.g. Libertinus → `t add libertinus-fonts`; STIX Two → `t add stix2-otf`")

    if names := by_kind.get("style"):
        warn("unknown biblatex style — check spelling or install the style package:")
        for n in names:
            print(f"  - style={n}")

    if names := by_kind.get("tikz-library"):
        warn("unknown tikz library — check spelling against ctan.org/pkg/pgf:")
        for n in names:
            print(f"  - \\usetikzlibrary{{{n}}}")

    if installable:
        pkgs: set[str] = set()
        for f in installable:
            pkgs |= search_one(f)
        if pkgs:
            cmd = f"t add {' '.join(sorted(pkgs))}"
            print()
            print(f"{C.G}suggested:{C.END} {C.BOLD}{cmd}{C.END}")
            if do_install:
                ans = input("\nrun this now? [y/N] ").strip().lower()
                if ans == "y":
                    return cmd_add(argparse.Namespace(pkgs=sorted(pkgs)))
        else:
            print()
            print(f"{C.R}note{C.END}  no tlmgr packages map to the missing files")
            print(f"      try `t search <name>` manually, or check the log")

    return 1  # nonzero so $failure_cmd-style callers know there was work to do

def cmd_missing(args):
    return cmd_diagnose(args, do_install=True)

def cmd_restore(args):
    m = load_manifest()
    pkgs = list(m.get("packages", {}).keys())
    if not pkgs:
        warn("no packages declared in tex-packages.toml")
        return 0
    info(f"installing {len(pkgs)} package(s) from manifest")
    r = subprocess.run(["tlmgr", "install", *pkgs])
    return r.returncode

# --- entry -----------------------------------------------------------------
def main():
    p = argparse.ArgumentParser(prog="t", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("search", help="search tlmgr by name and file")
    sp.add_argument("terms", nargs="+")
    sp.set_defaults(func=cmd_search)

    sp = sub.add_parser("add", help="install + record in manifest")
    sp.add_argument("pkgs", nargs="+")
    sp.set_defaults(func=cmd_add)

    sp = sub.add_parser("diagnose", help="parse a log and suggest installs")
    sp.add_argument("log", nargs="?")
    sp.set_defaults(func=cmd_diagnose)

    sp = sub.add_parser("missing", help="diagnose + install (with prompt)")
    sp.add_argument("log", nargs="?")
    sp.set_defaults(func=cmd_missing)

    sp = sub.add_parser("restore", help="install everything in the manifest")
    sp.set_defaults(func=cmd_restore)

    args = p.parse_args()
    sys.exit(args.func(args))

if __name__ == "__main__":
    main()
