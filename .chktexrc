# Silent lists commands that may end with a space without triggering warning 1.
# To silence a warning number, pass -n<N> on the command line (see Makefile).
# To silence a single line, add % chktex N at the end of that line.

Silent
{
    \pdfvariable
    \printbibliography
    \usephysicsmodule
    \DeclareMathOperator
}
